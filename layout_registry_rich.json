      ],
      "optional_blocks": [
        "subtitle",
        "background_image"
      ],
      "best_for": [
        "chuyển sang mục lớn",
        "phần I/II/III"
      ],
      "avoid_when": [
        "section quá nhỏ chỉ có một ý"
      ],
      "capacity_hint": {
        "max_words": 25
      },
      "supports": [
        "text_style",
        "background_image"
      ],
      "pml_example": ""
    },
