{
  "version": "0.3-rich",
  "description": "Layout registry đầy đủ hơn cho PML/PSL renderer, dùng cho slide planner chọn layout theo intent và đặc điểm nội dung.",
  "selection_policy": {
    "priority_order": [
      "respect_explicit_document_heading",
      "match_content_structure",
      "match_intent",
      "fit_capacity",
      "avoid_empty_or_overflow_slides"
    ],
    "ontology_role": "reference_only; do not create ontology sections absent from source document",
    "fallback_layouts": [
      "title-bullets",
      "two-column",
      "title-table"
    ],
    "avoid_subtitle_when": [
      "subtitle is metadata",
      "subtitle duplicates title",
      "subtitle is just ontology/layout/task label"
    ]
  },
  "layout_families": {
    "presentation": "deck-level cover pages",
    "section": "section dividers",
    "content": "text-centric slides",
    "mixed": "text plus image/table combinations",
    "image": "visual-centric slides",
    "grid": "multi-card layouts",
    "process": "sequence/progress/timeline layouts",
    "table": "tabular data layouts"
  },
  "layouts": [
    {
      "id": "title-slide",
      "family": "presentation",
      "intent": [
        "cover",
        "opening"
      ],
      "description": "Trang bìa của deck; dùng title chính, subtitle/author/date nếu có.",
      "required_blocks": [
        "title"
      ],
      "optional_blocks": [
        "subtitle",
        "author",
        "date",
        "background_image"
      ],
      "best_for": [
        "mở đầu báo cáo",
        "tên văn bản",
        "chủ đề chính"
      ],
      "avoid_when": [
        "nội dung chi tiết",
        "bảng số liệu"
      ],
      "capacity_hint": {
        "max_text_blocks": 4
      },
      "supports": [
        "text_style",
        "background_image"
      ],
      "pml_example": "cover_layout: title-slide"
    },
    {
      "id": "section-header",
      "family": "section",
      "intent": [
        "section_break",
        "chapter_start"
      ],
      "description": "Slide phân cách chương/phần, nhấn mạnh tên section.",
      "required_blocks": [
