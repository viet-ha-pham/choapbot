  "heading_selection_policy": {
    "min_sections": 4,
    "max_sections": 9,
    "always_consider": [
      "executive_summary",
      "situation_context",
      "implementation_results",
      "limitations_causes",
      "measures_solutions",
      "implementation_organization"
    ],
    "include_if_signaled": {
      "risks_warnings": [
        "rủi ro",
        "nhắc nhở",
        "chấn chỉnh",
        "cảnh báo"
      ],
      "tasks_assignment": [
        "giao",
        "phân công",
        "đầu mối",
        "thời hạn"
      ],
      "timeline_progress": [
        "tiến độ",
        "lộ trình",
        "deadline",
        "mốc"
      ],
      "data_metrics": [
        "%",
        "tỷ lệ",
        "số lượng",
        "chỉ tiêu",
        "lũy kế"
      ],
      "recommendations_proposals": [
        "kiến nghị",
        "đề xuất",
        "đề nghị"
      ]
    },
    "merge_rules": [
      {
        "if_both": [
          "implementation_results",
          "highlights"
        ],
        "allow_merge_title": "Kết quả thực hiện và điểm nổi bật"
      },
      {
        "if_both": [
          "limitations_causes",
          "risks_warnings"
        ],
        "allow_merge_title": "Tồn tại, rủi ro và nhắc nhở"
      },
      {
        "if_both": [
          "measures_solutions",
          "implementation_organization"
        ],
        "allow_merge_title": "Giải pháp và tổ chức thực hiện"
      }
    ]
  },
  "output_contract": {
    "report_title": "string",
    "document_type": "one document type id",
    "subtitle": "string",
    "author_or_unit": "string",
    "reporting_period": "string|null",
    "sections": [
      {
        "concept_id": "one concept id above",
        "heading": "preferred heading or custom heading",
        "intent": "intent string",
        "summary": "one concise paragraph",
        "bullets": [
          "short bullet, evidence-grounded"
        ],
        "metrics": [
          {
            "name": "string",
            "value": "string",
            "period": "string",
            "comment": "string"
          }
        ],
        "table": {
          "headers": [
            "col"
          ],
          "rows": [
            [
              "cell"
            ]
          ]
        },
        "milestones": [
          {
            "date": "string",
            "heading": "string",
            "text": "string"
          }
        ],
        "tasks": [
          {
            "owner": "string",
            "task": "string",
            "deadline": "string",
            "deliverable": "string"
          }
        ],
        "takeaway": "one sentence"
      }
    ]
  },
  "prompting_guidance": {
    "style": "Vietnamese administrative but concise; avoid fabricating facts; preserve numbers, dates, units, agency names.",
    "anti_hallucination": [
      "Only use facts present in the source.",
      "If a heading has no evidence, omit it or mark as not found.",
      "Do not invent deadlines, owners, metrics, or conclusions."
    ],
    "extraction_order": [
      "identify document type",
      "detect section signals",
      "extract evidence into ontology concepts",
      "select strongest headings",
      "compress into slide-ready bullets"
    ]
  },
  "usage_policy": {
    "document_outline_first": true,
    "ontology_role": "reference_only",
    "do_not_force_missing_sections": true,
    "subtitle_policy": "Only create subtitles when they express substantive meaning; never use metadata such as task id, source heading, layout, ontology, renderer.",
    "summary_policy": "Do not end summaries with ellipsis; prefer complete concise sentences."
  },
  "exclusion_rules": {
    "ignore_opening_motto": true,
    "ignore_recipients_tail": true,
    "ignored_heading_patterns": [
      "^cộng\\s+hòa\\s+xã\\s+hội\\s+chủ\\s+nghĩa\\s+việt\\s+nam$",
      "^độc\\s+lập\\s*[-–—]\\s*tự\\s+do\\s*[-–—]\\s*hạnh\\s+phúc$",
      "^nơi\\s+nhận\\s*:?$",
      "^kính\\s+gửi\\s*:?$",
      "^số\\s*[:：]\\s*.*$",
      "^số\\s+.*$",
      "^.*cộng\\s+h[oòóọõỏôồốộỗổơờớợỡở][aàáạãả]\\s+x[aã]\\s+h[oộòóọõỏ]i\\s+ch[uủ]\\s+ngh[iĩ]a\\s+vi[eệ]t\\s+nam.*$",
      "^tm\\.?\\s+.*$",
      "^kt\\.?\\s+.*$",
      "^chủ\\s+tịch.*$",
      "^phó\\s+chủ\\s+tịch.*$",
      "^người\\s+ký.*$",
      "^\\(\\s*đã\\s+ký\\s*\\).*$"
    ],
    "ignored_sections": [
      {
        "name": "Quốc hiệu và tiêu ngữ",
        "examples": [
          "CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM",
          "Độc lập - Tự do - Hạnh phúc"
        ],
        "reason": "Nghi thức mở đầu, không phải nội dung báo cáo."
      },
      {
        "name": "Nơi nhận",
        "examples": [
          "Nơi nhận:",
          "- Như trên;",
          "- Lưu: VT."
        ],
        "reason": "Danh sách phát hành cuối văn bản, không tạo slide nội dung."
      }
    ],
    "ignore_document_number_header": true,
    "ignore_opening_state_title_and_motto": true,
    "ignore_signature_block": true,
    "description": "Loại bỏ boilerplate hành chính: Số văn bản, quốc hiệu/tiêu ngữ, nơi nhận, ký tá/chức danh cuối văn bản; không dùng các dòng này để tóm tắt hoặc tạo slide."
  }
}